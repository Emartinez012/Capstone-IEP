CREATE OR REPLACE VIEW "public"."v_substitution_queue" AS
 SELECT cs.substitution_id,
    cs.substitution_status,
    s_user.first_name AS student_first_name,
    s_user.last_name AS student_last_name,
    cs.required_course_code,
    cs.external_course_id,
    cs.institution_name,
    cs.submitted_at,
    a_user.first_name AS reviewer_first_name,
    a_user.last_name AS reviewer_last_name
   FROM course_substitutions cs
     LEFT JOIN users s_user ON cs.student_user_id = s_user.user_id
     LEFT JOIN users a_user ON cs.assigned_reviewer_id = a_user.user_id;;

