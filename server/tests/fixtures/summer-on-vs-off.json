{
  "name": "Summer on vs. off — same model produces different semester counts",
  "shape": "iep_generator",
  "description": "Identical 4-course model run twice: once with takes_summer=false (only Fall+Spring terms appear) and once with takes_summer=true (Fall, Spring, Summer all appear). With 1 course/sem, summer-off needs 4 semesters across two academic years; summer-on needs 4 semesters spanning Fall→Spring→Summer→Fall. Term codes must reflect which terms are skipped.",
  "input": {
    "programModel": {
      "program_id": "TEST-SUMMER",
      "total_credits_required": 12,
      "rows": [
        { "priority": 1, "course_id": "S1", "level": 1, "is_elective": false, "category": "MAJOR", "credits": 3, "prerequisites": [] },
        { "priority": 2, "course_id": "S2", "level": 1, "is_elective": false, "category": "MAJOR", "credits": 3, "prerequisites": [] },
        { "priority": 3, "course_id": "S3", "level": 1, "is_elective": false, "category": "MAJOR", "credits": 3, "prerequisites": [] },
        { "priority": 4, "course_id": "S4", "level": 1, "is_elective": false, "category": "MAJOR", "credits": 3, "prerequisites": [] }
      ]
    },
    "variants": {
      "summer_off": {
        "studentProfile": {
          "starting_term": "261",
          "takes_summer": false,
          "target_courses_fall_spring": 1,
          "target_credits_fall_spring": 3,
          "target_courses_summer": 0,
          "target_credits_summer": 0
        }
      },
      "summer_on": {
        "studentProfile": {
          "starting_term": "261",
          "takes_summer": true,
          "target_courses_fall_spring": 1,
          "target_credits_fall_spring": 3,
          "target_courses_summer": 1,
          "target_credits_summer": 3
        }
      }
    },
    "completedCourses": []
  },
  "expectations": {
    "summer_off": {
      "term_codes_in_order": ["261", "262", "271", "272"],
      "no_summer_terms": true
    },
    "summer_on": {
      "term_codes_in_order": ["261", "262", "263", "271"],
      "summer_terms_present": ["263"]
    }
  }
}
